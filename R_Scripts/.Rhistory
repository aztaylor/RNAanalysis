# Hierarchical clustering
# Use the cosine similarity which is ideal for text data.
BoW_cosine_matrix <- as.matrix(BoW_dtm)
BoW_cosine_sim <- lsa::cosine(t(BoW_cosine_matrix))
BoW_cosine_dist <- as.dist(1 - BoW_cosine_sim)
