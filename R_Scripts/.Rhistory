keytype = "SYMBOL",
column = "ENTREZID",
multiVals = "first"
)) %>%
unique()
go_df <-  AnnotationDbi::select(up,
keys = all_genes$ENTREZID,
columns = c("go_p"),
keytype = "GeneID"
)
go_results <- all_genes %>%
inner_join(go_df,
by = c("ENTREZID" = "From")
) %>%
rename(
UniProtID = Entry,
Functions = colnames(.)[[4]]
)
if (nrow(go_results) > 0 ) {
processed <- go_results %>%
# Extract all term-GO pairs
mutate(pairs = str_split(Functions, ";\\s*")) %>%
unnest(pairs) %>%
filter(pairs != "") %>%
# Extract clean terms
mutate(
function_term = str_remove(pairs, "\\s*\\[[^]]+\\]\\s*") %>% str_trim(),
go_term = str_extract(pairs, "\\[[^]]+\\]")
) %>%
# Remove gene/protein IDs (customize filters as needed)
filter(
!str_detect(function_term, "^[A-Z0-9]{6,}$")
)
} else {
tibble(Gene = gene, Functions = NA_character_, GO_IDs = NA_character_)
} %>%
bind_rows() %>%
distinct(Gene, .keep_all = TRUE)
functions <- sapply(results, function(x) x$protein$recommendedName$fullName$value)
# Function to safely extract GO terms
get_go_terms <- function(entry) {
if (!is.null(entry$dbReferences) &&
"type" %in% names(entry$dbReferences)) {
go_terms <- entry$dbReferences[entry$dbReferences$type == "GO", ]
if (nrow(go_terms) > 0) {
return(go_terms[, c("id", "properties.term")])
}
}
return(data.frame(id=character(), term=character())) # Empty df if no GO terms
}
