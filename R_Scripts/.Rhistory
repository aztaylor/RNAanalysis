ggsave("../Figures/trt_compNC_vs_s4.png", trt_comp, dpi=600)
genes <- heatmap_data_sorted$Gene
# Fetch UniProt data for all genes
results <- lapply(genes, function(gene) {
url <- paste0("https://www.ebi.ac.uk/proteins/api/proteins?gene=", gene)
response <- GET(url, accept("application/json"))
fromJSON(rawToChar(response$content))
})
# Extract functions
sapply(results, function(x) x$protein$recommendedName$fullName$value)
functions <- sapply(results, function(x) x$protein$recommendedName$fullName$value)
# Function to safely extract GO terms
get_go_terms <- function(entry) {
if (!is.null(entry$dbReferences) &&
"type" %in% names(entry$dbReferences)) {
go_terms <- entry$dbReferences[entry$dbReferences$type == "GO", ]
if (nrow(go_terms) > 0) {
return(go_terms[, c("id", "properties.term")])
}
}
return(data.frame(id=character(), term=character())) # Empty df if no GO terms
}
